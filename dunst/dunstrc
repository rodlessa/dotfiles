[global]
    # Configurações de geometria e posicionamento
    width = 300
    height = (0,300)
    origin = top-right
    offset = (20,50)
    padding = 10
    horizontal_padding = 10
    text_icon_padding = 10
    
    # Estilo das bordas e background
    frame_width = 2
    separator_height = 0
    font = JetBrainsMono Nerd Font 10
    
    # Cores inspiradas no seu Waybar
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#89b4fa"
    corner_radius = 15

[urgency_low]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    timeout = 5

[urgency_normal]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    timeout = 10

[urgency_critical]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#f38ba8" # Mantém o rosa para urgentes (como no seu workspace)
    timeout = 0
